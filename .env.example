# Base URL for the TestForge backend API. Should include /api at the end.
# Examples:
#   Local dev (uses vite proxy):   VITE_API_BASE=/api
#   Staging:                       VITE_API_BASE=https://staging.example.com/api
#   Production:                    VITE_API_BASE=https://testgenie-backend-g9fu.onrender.com/api
#
# If unset, the app falls back to /api on localhost and the production URL elsewhere.
VITE_API_BASE=/api
